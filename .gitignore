# .gitignore — Dark Factory

# Dependencies
node_modules/

# Environment (API keys!)
.env

# Generated target app (runtime output, not source)
workspace/
# Note: mock-workspace/ is committed (used for mock-fast and demo modes)

# Runtime state
state/current.json
state/cost-tracking.json

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Logs
*.log

# Archives (generated zips for download)
*.zip

# Upload folder (temporary files for sharing)
upload/

/state/