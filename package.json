{
    "name": "dark-factory",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "start": "node server/index.js",
        "dev": "node --watch server/index.js",
        "restart": "npx kill-port 3000 && npm start",
        "clean": "node -e \"const fs=require('fs'); try{fs.unlinkSync('state/current.json')}catch(e){} try{fs.rmSync('workspace',{recursive:true,force:true})}catch(e){}\"",
        "fresh": "npm run clean && npm run restart",
        "mock:fast": "set RUN_MODE=mock-fast&& npm run restart",
        "mock:full": "set RUN_MODE=mock-full&& npm run clean && npm run restart",
        "demo": "set RUN_MODE=demo&& npm run restart"
    },
    "dependencies": {
        "archiver": "^7.0.1",
        "dotenv": "^17.4.2",
        "express": "^5.1.0",
        "node-fetch": "^3.3.2"
    }
}
