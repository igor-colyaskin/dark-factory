# OpenRouter API Key (required for production mode)
OPENROUTER_API_KEY=sk-or-ВСТАВЬ-СВОЙ-КЛЮЧ

# Fly.io Configuration (required for v0.2 deployment)
# Get your token: flyctl auth token
# Get your org: flyctl orgs list
FLY_API_TOKEN=your-fly-api-token-here
FLY_ORG_SLUG=your-org-slug-here

# Run Mode:
# - production (default): Real OpenRouter API calls, writes to workspace/
# - mock-full: Mock responses, writes to workspace/ (for testing File Manager)
# - mock-fast: Mock responses, uses pre-built mock-workspace/ (fastest)
# - demo: Mock responses, uses mock-workspace/, slower delays for presentations
# RUN_MODE=production
# RUN_MODE=mock-full
# RUN_MODE=mock-fast
# RUN_MODE=demo

# Server Port (default: 3000)
# PORT=3000